# Copier vers .env et adapter
#
# Rôles : l’interface acheteur est réservée aux superusers Django et aux
# utilisateurs du groupe « Responsable Achat » (créé par la migration).
# Admin Django → Utilisateurs → ajouter l’utilisateur au groupe « Responsable Achat ».
DJANGO_SECRET_KEY=changez-moi-en-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Base : sqlite3 (défaut) ou postgresql
DJANGO_DATABASE_ENGINE=sqlite3
# POSTGRES_DB=drp
# POSTGRES_USER=drp
# POSTGRES_PASSWORD=
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# Email : SMTP réel, ou console pour développement
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=drp@example.com

# Liens dans les mails (sans slash final)
SITE_PUBLIC_URL=http://127.0.0.1:8000

# Uploads
MAX_PDF_UPLOAD_BYTES=5242880

# Analyse IA (Claude) — obtenez une clé sur console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Production (DEBUG=false)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
